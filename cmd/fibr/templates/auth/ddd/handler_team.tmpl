// RegisterAuthDocs documents the auth routes in the OpenAPI spec.
func RegisterAuthDocs(oapi *openapi.Spec) {
	oapi.Register("POST", "/auth/register", openapi.Op{
		Summary: "Register a new account", Tags: []string{"auth"},
		Request: credentials{}, Status: 201,
	})
	oapi.Register("POST", "/auth/login", openapi.Op{
		Summary: "Log in", Tags: []string{"auth"},
		Request: credentials{}, Response: auth.TokenPair{},
	})
	oapi.Register("POST", "/auth/refresh", openapi.Op{
		Summary: "Refresh tokens", Tags: []string{"auth"},
		Request: refreshRequest{}, Response: auth.TokenPair{},
	})
}

// AuthHandler exposes the auth and team routes.
type AuthHandler struct {
	accounts *appaccount.Service
	teams    *appteam.Service
	secret   string
	issuer   *auth.Issuer
	store    auth.TokenStore
}

// NewAuthHandler creates an AuthHandler.
func NewAuthHandler(accounts *appaccount.Service, teams *appteam.Service, secret string, store auth.TokenStore) *AuthHandler {
	return &AuthHandler{accounts: accounts, teams: teams, secret: secret, issuer: auth.NewIssuer(secret, store), store: store}
}

type credentials struct {
	Email    string `json:"email" validate:"required,email"`
	Password string `json:"password" validate:"required"`
}

type refreshRequest struct {
	RefreshToken string `json:"refresh_token" validate:"required"`
}

// RegisterRoutes mounts the /auth, /permissions, and /teams routes.
func (h *AuthHandler) RegisterRoutes(r fiber.Router) {
	g := r.Group("/auth")
	g.Post("/register", h.register)
	g.Post("/login", h.login)
	g.Post("/refresh", h.refresh)
	g.Post("/logout", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)), h.logout)
	g.Post("/switch-team", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)), h.switchTeam)
	g.Get("/me", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)), h.me)

	r.Get("/permissions", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)), h.permissions)
	r.Post("/invitations/accept", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)), h.acceptInvitation)

	t := r.Group("/teams", auth.RequireAuth(h.secret, auth.WithBlocklist(h.store)))
	t.Get("/", h.listTeams)
	t.Post("/", h.createTeam)
	t.Post("/:id/members", auth.RequireScope("member:manage"), h.addMember)
	t.Put("/:id/members", auth.RequireScope("member:manage"), h.changeMemberRole)
	t.Get("/:id/roles", auth.RequireScope("role:manage"), h.listRoles)
	t.Post("/:id/roles", auth.RequireScope("role:manage"), h.createRole)
	t.Put("/:id/roles/:name", auth.RequireScope("role:manage"), h.updateRole)
	t.Delete("/:id/roles/:name", auth.RequireScope("role:manage"), h.deleteRole)
	t.Post("/:id/invitations", auth.RequireScope("member:manage"), h.inviteMember)
	t.Get("/:id/invitations", auth.RequireScope("member:manage"), h.listInvitations)
	t.Delete("/:id/invitations/:inviteID", auth.RequireScope("member:manage"), h.revokeInvitation)
	t.Patch("/:id", auth.RequireScope("team:manage"), h.renameTeam)
	t.Delete("/:id", auth.RequireScope("team:manage"), h.deleteTeam)
	t.Post("/:id/transfer", auth.RequireScope("team:manage"), h.transferOwnership)
	t.Delete("/:id/members", auth.RequireScope("member:manage"), h.removeMember)
	t.Delete("/:id/members/me", h.leaveTeam)
	t.Get("/:id/manage", auth.RequireScope("team:manage"), h.manage)
}

// teamClaims builds JWT claims for an account active in a membership with the
// resolved permission set.
func teamClaims(sub, email string, m *teamdomain.Membership, perms []string) jwt.MapClaims {
	return jwt.MapClaims{
		"sub":    sub,
		"email":  email,
		"team":   strconv.FormatInt(m.TeamID, 10),
		"role":   m.Role,
		"scopes": perms,
	}
}

// sameTeam reports whether the caller's active team matches the path :id team.
func (h *AuthHandler) sameTeam(c *fiber.Ctx) bool {
	return auth.ActiveTeam(c) == c.Params("id")
}

func (h *AuthHandler) register(c *fiber.Ctx) error {
	in, ok := bind.Body[credentials](c)
	if !ok {
		return nil
	}
	a, err := h.accounts.Register(c.UserContext(), in.Email, in.Password)
	if err != nil {
		if errors.Is(err, appaccount.ErrEmailTaken) {
			return apierror.Conflict("email already registered").WithCode("email_taken")
		}
		return apierror.Internal("could not create account")
	}
	team, err := h.teams.CreatePersonalTeam(c.UserContext(), a.ID, a.Email)
	if err != nil {
		return response.SendError(c, nil, "could not create team", fiber.StatusInternalServerError)
	}
	return response.SendSuccess(c, fiber.Map{
		"id":    a.ID,
		"email": a.Email,
		"team":  fiber.Map{"id": team.ID, "name": team.Name, "slug": team.Slug, "role": "owner"},
	}, "created", fiber.StatusCreated)
}

func (h *AuthHandler) login(c *fiber.Ctx) error {
	in, ok := bind.Body[credentials](c)
	if !ok {
		return nil
	}
	a, err := h.accounts.Authenticate(c.UserContext(), in.Email, in.Password)
	if err != nil {
		return apierror.Unauthorized("invalid credentials")
	}
	m, err := h.teams.DefaultMembership(c.UserContext(), a.ID)
	if err != nil {
		// Self-heal: an account with no team (e.g. team creation failed at
		// register) gets a personal team on first successful login.
		t, cerr := h.teams.CreatePersonalTeam(c.UserContext(), a.ID, a.Email)
		if cerr != nil {
			return response.SendError(c, nil, "could not create team", fiber.StatusInternalServerError)
		}
		m = &teamdomain.Membership{AccountID: a.ID, TeamID: t.ID, Role: "owner"}
	}
	perms, err := h.teams.PermissionsForRole(c.UserContext(), m.TeamID, m.Role)
	if err != nil {
		return response.SendError(c, nil, "could not resolve permissions", fiber.StatusInternalServerError)
	}
	pair, err := h.issuer.Issue(c.UserContext(), teamClaims(strconv.FormatInt(a.ID, 10), a.Email, m, perms))
	if err != nil {
		return apierror.Internal("could not issue token")
	}
	return response.SendSuccess(c, pair, "ok")
}

func (h *AuthHandler) refresh(c *fiber.Ctx) error {
	in, ok := bind.Body[refreshRequest](c)
	if !ok {
		return nil
	}
	pair, err := h.issuer.Refresh(c.UserContext(), in.RefreshToken)
	if err != nil {
		if errors.Is(err, auth.ErrTokenReuse) {
			log.Warn().Str("event", "refresh_reuse").Msg("refresh token reuse detected")
		}
		return apierror.Unauthorized("invalid refresh token")
	}
	return response.SendSuccess(c, pair, "ok")
}

func (h *AuthHandler) logout(c *fiber.Ctx) error {
	// Strip the bearer prefix case-insensitively, matching auth.RequireAuth.
	const bearerPrefix = "Bearer "
	authz := c.Get("Authorization")
	var access string
	if len(authz) > len(bearerPrefix) && strings.EqualFold(authz[:len(bearerPrefix)], bearerPrefix) {
		access = authz[len(bearerPrefix):]
	}
	var in refreshRequest
	_ = c.BodyParser(&in)
	if err := h.issuer.Logout(c.UserContext(), access, in.RefreshToken); err != nil {
		return apierror.Internal("could not log out")
	}
	return response.SendSuccess(c, fiber.Map{"ok": true}, "logged out")
}

func (h *AuthHandler) switchTeam(c *fiber.Ctx) error {
	var in struct {
		TeamID int64 `json:"team_id"`
	}
	if err := c.BodyParser(&in); err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusBadRequest)
	}
	accountID, err := strconv.ParseInt(auth.Subject(c), 10, 64)
	if err != nil {
		return response.SendError(c, nil, "invalid subject", fiber.StatusUnauthorized)
	}
	m, err := h.teams.Membership(c.UserContext(), accountID, in.TeamID)
	if err != nil {
		return response.SendError(c, nil, "not a member of that team", fiber.StatusForbidden)
	}
	perms, err := h.teams.PermissionsForRole(c.UserContext(), m.TeamID, m.Role)
	if err != nil {
		return response.SendError(c, nil, "could not resolve permissions", fiber.StatusInternalServerError)
	}
	email := ""
	if claims, ok := auth.Claims(c); ok {
		email, _ = claims["email"].(string)
	}
	pair, err := h.issuer.Issue(c.UserContext(), teamClaims(auth.Subject(c), email, m, perms))
	if err != nil {
		return apierror.Internal("could not issue token")
	}
	return response.SendSuccess(c, pair, "ok")
}

func (h *AuthHandler) me(c *fiber.Ctx) error {
	email := ""
	if claims, ok := auth.Claims(c); ok {
		email, _ = claims["email"].(string)
	}
	return response.SendSuccess(c, fiber.Map{
		"sub":         auth.Subject(c),
		"email":       email,
		"team":        auth.ActiveTeam(c),
		"role":        auth.TeamRole(c),
		"permissions": auth.Scopes(c),
	}, "ok")
}

func (h *AuthHandler) permissions(c *fiber.Ctx) error {
	return response.SendSuccess(c, appteam.AllPermissions, "ok")
}

func (h *AuthHandler) listTeams(c *fiber.Ctx) error {
