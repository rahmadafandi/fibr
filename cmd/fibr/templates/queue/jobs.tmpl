package jobs

import (
	"context"
	"log"

	fhjobs "github.com/rahmadafandi/fibr/jobs"
{{if .Mailer}}	fhmailer "github.com/rahmadafandi/fibr/mailer"
{{end}})

// WelcomeType is the task type for the welcome-email job.
const WelcomeType = "welcome:send"

// WelcomePayload is the JSON payload for a welcome job.
type WelcomePayload struct {
	Email string `json:"email"`
}
{{if .Mailer}}
const welcomeHTML = `<p>Welcome, {{"{{"}}.Email{{"}}"}}!</p>`
const welcomeText = "Welcome, {{"{{"}}.Email{{"}}"}}!"

// Register wires this app's job handlers onto the worker server, sending mail
// through sender.
func Register(srv *fhjobs.Server, sender fhmailer.Sender) {
	fhjobs.Handle[WelcomePayload](srv, WelcomeType, func(ctx context.Context, p WelcomePayload) error {
		html, text, err := fhmailer.Render(welcomeHTML, welcomeText, p)
		if err != nil {
			return err
		}
		return sender.Send(ctx, fhmailer.Message{To: []string{p.Email}, Subject: "Welcome", HTML: html, Text: text})
	})
	fhjobs.Handle[CleanupPayload](srv, CleanupType, HandleCleanup)
}

// EmailType is the generic email-send job type.
const EmailType = "email:send"

// QueueSender enqueues messages as email:send jobs instead of sending inline.
// It satisfies fhmailer.Sender, so request-path consumers can send asynchronously.
type QueueSender struct {
	client *fhjobs.Client
}

// NewQueueSender returns a QueueSender backed by client.
func NewQueueSender(client *fhjobs.Client) *QueueSender {
	return &QueueSender{client: client}
}

// Send enqueues msg as an email:send job.
func (q *QueueSender) Send(ctx context.Context, msg fhmailer.Message) error {
	_, err := q.client.Enqueue(ctx, EmailType, msg)
	return err
}

// RegisterEmail registers the email:send handler, delivering via base.
func RegisterEmail(srv *fhjobs.Server, base fhmailer.Sender) {
	fhjobs.Handle[fhmailer.Message](srv, EmailType, base.Send)
}
{{else}}
// HandleWelcome processes a welcome job. Wire a mailer (generate with --mailer)
// to send a real email here.
func HandleWelcome(ctx context.Context, p WelcomePayload) error {
	log.Printf("sending welcome to %s", p.Email)
	return nil
}

// Register wires this app's job handlers onto the worker server.
func Register(srv *fhjobs.Server) {
	fhjobs.Handle[WelcomePayload](srv, WelcomeType, HandleWelcome)
	fhjobs.Handle[CleanupPayload](srv, CleanupType, HandleCleanup)
}
{{end}}

// CleanupType is the task type for the periodic cleanup job.
const CleanupType = "cleanup:run"

// CleanupPayload is the JSON payload for a cleanup job.
type CleanupPayload struct {
	OlderThanDays int `json:"older_than_days"`
}

// HandleCleanup processes a cleanup job. Replace the body with real cleanup
// (e.g. delete stale rows) for your app.
func HandleCleanup(ctx context.Context, p CleanupPayload) error {
	log.Printf("cleanup: removing data older than %d days", p.OlderThanDays)
	return nil
}

// RegisterSchedule registers this app's periodic (cron) jobs on the scheduler.
func RegisterSchedule(sched *fhjobs.Scheduler) error {
	// Daily at 02:00 (scheduler time zone; UTC by default).
	_, err := sched.Register("0 2 * * *", CleanupType, CleanupPayload{OlderThanDays: 30})
	return err
}
