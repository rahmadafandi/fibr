package handler

import (
	"strconv"

	"github.com/gofiber/fiber/v2"
	"github.com/rahmadafandi/fibr/bind"
	"github.com/rahmadafandi/fibr/response"
	"{{.Module}}/internal/model"
	"{{.Module}}/internal/service"
)

// {{.Type}}Handler exposes {{.Pkg}} HTTP routes.
type {{.Type}}Handler struct {
	svc *service.{{.Type}}Service
}

// New{{.Type}}Handler creates a {{.Type}}Handler.
func New{{.Type}}Handler(svc *service.{{.Type}}Service) *{{.Type}}Handler {
	return &{{.Type}}Handler{svc: svc}
}

// RegisterRoutes mounts the {{.Pkg}} routes under /{{.Plural}}.
func (h *{{.Type}}Handler) RegisterRoutes(app fiber.Router) {
	g := app.Group("/{{.Plural}}")
	g.Get("/", h.list)
	g.Get("/:id", h.get)
	g.Post("/", h.create)
}

func (h *{{.Type}}Handler) list(c *fiber.Ctx) error {
	items, err := h.svc.List(c.UserContext())
	if err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
	}
	return response.SendSuccess(c, items, "ok")
}

func (h *{{.Type}}Handler) get(c *fiber.Ctx) error {
	id, err := strconv.ParseInt(c.Params("id"), 10, 64)
	if err != nil {
		return response.SendError(c, nil, "invalid id", fiber.StatusBadRequest)
	}
	e, err := h.svc.Get(c.UserContext(), id)
	if err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusNotFound)
	}
	return response.SendSuccess(c, e, "ok")
}

func (h *{{.Type}}Handler) create(c *fiber.Ctx) error {
	e, ok := bind.Body[model.{{.Type}}](c)
	if !ok {
		return nil
	}
	if err := h.svc.Create(c.UserContext(), &e); err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
	}
	return response.SendSuccess(c, e, "created", fiber.StatusCreated)
}
