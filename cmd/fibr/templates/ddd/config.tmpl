package config

import fhconfig "github.com/rahmadafandi/fibr/config"

// Config holds all environment-driven configuration for {{.Name}}.
type Config struct {
	DatabaseURL string `mapstructure:"DATABASE_URL" default:"{{if eq .DB "postgres"}}postgres://app:app@localhost:5432/app?sslmode=disable{{else}}file:./data/app.db?cache=shared{{end}}"`
	Port        string `mapstructure:"PORT" default:"3000"`
	LogLevel    string `mapstructure:"LOG_LEVEL" default:"info"`
	AutoMigrate bool   `mapstructure:"AUTO_MIGRATE" default:"false"`
	MetricsEnabled bool `mapstructure:"METRICS_ENABLED" default:"false"`
	TracingEnabled bool `mapstructure:"TRACING_ENABLED" default:"false"`
{{if .Auth}}	JWTSecret string `mapstructure:"JWT_SECRET" required:"true"`
{{end}}{{if or .Auth .Queue}}	RedisURL  string `mapstructure:"REDIS_URL"`
{{end}}{{if .Queue}}	QueueConcurrency int    `mapstructure:"QUEUE_CONCURRENCY" default:"10"`
	AsynqmonPath     string `mapstructure:"ASYNQMON_PATH" default:"/monitoring"`
{{end}}{{if .Mailer}}	SMTPHost     string `mapstructure:"SMTP_HOST"`
	SMTPPort     int    `mapstructure:"SMTP_PORT" default:"587"`
	SMTPUsername string `mapstructure:"SMTP_USERNAME"`
	SMTPPassword string `mapstructure:"SMTP_PASSWORD"`
	SMTPFrom     string `mapstructure:"SMTP_FROM" default:"no-reply@example.com"`
{{end}}}

// Load reads configuration from environment variables and defaults.
func Load() (*Config, error) {
	var c Config
	if err := fhconfig.LoadConfig(&c); err != nil {
		return nil, err
	}
	return &c, nil
}
