func main() {
	root := &cobra.Command{
		Use:          "{{.Name}}",
		Short:        "{{.Name}} server",
		Long:         "Run without a subcommand (or with \"serve\") to start the HTTP server. Use \"migrate\" for database migrations.",
		SilenceUsage: true,
	}
	root.RunE = func(cmd *cobra.Command, args []string) error { return runServe(false) }
	root.AddCommand(serveCmd())
	root.AddCommand(fhmigrate.NewCommand(openDB, migrations.Migrations))
{{if .Queue}}	root.AddCommand(workerCmd())
	root.AddCommand(schedulerCmd())
{{end}}	if err := root.Execute(); err != nil {
		log.Fatal(err)
	}
}

func serveCmd() *cobra.Command {
	var autoMigrate bool
	cmd := &cobra.Command{
		Use:   "serve",
		Short: "run the HTTP server",
		RunE:  func(cmd *cobra.Command, args []string) error { return runServe(autoMigrate) },
	}
	cmd.Flags().BoolVar(&autoMigrate, "auto-migrate", false, "create tables at startup (dev)")
	return cmd
}

{{if .Queue}}func workerCmd() *cobra.Command {
	return &cobra.Command{
		Use:   "worker",
		Short: "run the background job worker",
		RunE:  func(cmd *cobra.Command, args []string) error { return runWorker() },
	}
}

func runWorker() error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	if cfg.RedisURL == "" {
		return fmt.Errorf("worker requires REDIS_URL")
	}
	opt, err := fhjobs.RedisConnOpt(cfg.RedisURL)
	if err != nil {
		return err
	}
	srv := fhjobs.NewServer(opt, fhjobs.ServerConfig{Concurrency: cfg.QueueConcurrency})
{{if .Mailer}}	base, _ := fhmailer.New(fhmailer.SMTPConfig{
		Host:     cfg.SMTPHost,
		Port:     cfg.SMTPPort,
		Username: cfg.SMTPUsername,
		Password: cfg.SMTPPassword,
		From:     cfg.SMTPFrom,
	})
	appjobs.Register(srv, base)
	appjobs.RegisterEmail(srv, base)
{{else}}	appjobs.Register(srv)
{{end}}	log.Println("worker started")
	return srv.Run()
}

func schedulerCmd() *cobra.Command {
	return &cobra.Command{
		Use:   "scheduler",
		Short: "run the periodic job scheduler",
		RunE:  func(cmd *cobra.Command, args []string) error { return runScheduler() },
	}
}

func runScheduler() error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	if cfg.RedisURL == "" {
		return fmt.Errorf("scheduler requires REDIS_URL")
	}
	opt, err := fhjobs.RedisConnOpt(cfg.RedisURL)
	if err != nil {
		return err
	}
	sched := fhjobs.NewScheduler(opt)
	if err := appjobs.RegisterSchedule(sched); err != nil {
		return err
	}
	log.Println("scheduler started")
	return sched.Run()
}

{{end}}func runServe(autoMigrate bool) error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	var dbOpts []fhdatabase.Option
	if cfg.TracingEnabled {
		dbOpts = append(dbOpts, fhdatabase.WithTracing())
	}
	db, err := database.New(cfg.DatabaseURL, dbOpts...)
	if err != nil {
		return err
	}

	var cleanups []func(context.Context) error
	if cfg.TracingEnabled {
		shutdown, terr := tracing.Setup(context.Background(), tracing.WithServiceName("{{.Name}}"))
		if terr != nil {
			log.Printf("tracing setup failed; continuing without tracing: %v", terr)
		} else {
			cleanups = append(cleanups, shutdown)
		}
	}

{{if .Queue}}	var queueClient *fhjobs.Client
	var asynqmonMount *bootstrap.AsynqmonMount
	if cfg.RedisURL != "" {
		opt, qerr := fhjobs.RedisConnOpt(cfg.RedisURL)
		if qerr != nil {
			return qerr
		}
		queueClient = fhjobs.NewClient(opt)
		cleanups = append(cleanups, func(ctx context.Context) error { return queueClient.Close() })
		asynqmonMount = &bootstrap.AsynqmonMount{
{{if not .Auth}}			// NOTE: the monitoring UI is unauthenticated. Add a Middleware guard (or regenerate with --auth) before exposing it publicly.
