package http

import (
	"strconv"

	"github.com/gofiber/fiber/v2"
	"github.com/rahmadafandi/fiber-helpers/response"
	appuser "{{.Module}}/internal/application/user"
	domain "{{.Module}}/internal/domain/user"
)

func registerUserRoutes(app fiber.Router, svc *appuser.Service) {
	g := app.Group("/users")
	g.Get("/", func(c *fiber.Ctx) error {
		users, err := svc.List(c.UserContext())
		if err != nil {
			return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
		}
		return response.SendSuccess(c, users, "ok")
	})
	g.Get("/:id", func(c *fiber.Ctx) error {
		id, err := strconv.ParseInt(c.Params("id"), 10, 64)
		if err != nil {
			return response.SendError(c, nil, "invalid id", fiber.StatusBadRequest)
		}
		u, err := svc.Get(c.UserContext(), id)
		if err != nil {
			return response.SendError(c, nil, err.Error(), fiber.StatusNotFound)
		}
		return response.SendSuccess(c, u, "ok")
	})
	g.Post("/", func(c *fiber.Ctx) error {
		var u domain.User
		if err := c.BodyParser(&u); err != nil {
			return response.SendError(c, nil, err.Error(), fiber.StatusBadRequest)
		}
		if err := svc.Create(c.UserContext(), &u); err != nil {
			return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
		}
		return response.SendSuccess(c, u, "created", fiber.StatusCreated)
	})
}
