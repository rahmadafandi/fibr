package main

import (
	"fmt"
	"log"

	"{{.Module}}/internal/infrastructure/config"
	"{{.Module}}/internal/infrastructure/database"
	httpiface "{{.Module}}/internal/interface/http"
	"github.com/rahmadafandi/fiber-helpers/bootstrap"
	"github.com/rahmadafandi/fiber-helpers/health"
)

func main() {
	cfg, err := config.Load()
	if err != nil {
		log.Fatal(err)
	}

	db, err := database.New(cfg.DatabaseURL)
	if err != nil {
		log.Fatal(err)
	}

	app := bootstrap.New(bootstrap.Options{
		DB:           db,
		EnableCORS:   true,
		RateLimit:    100,
		HealthChecks: []health.NamedCheck{health.PingBun(db)},
	})

	httpiface.Register(app.App)
{{if .Sample}}	if err := app.Mount(httpiface.NewUserModule(db)); err != nil {
		log.Fatal(err)
	}
{{end}}
	fmt.Printf("listening on :%s\n", cfg.Port)
	log.Fatal(app.Run(":" + cfg.Port))
}
