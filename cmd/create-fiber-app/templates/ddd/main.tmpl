package main

import (
	"context"
	"fmt"
	"log"

	"github.com/rahmadafandi/fiber-helpers/bootstrap"
	"github.com/rahmadafandi/fiber-helpers/health"
	fhmigrate "github.com/rahmadafandi/fiber-helpers/migrate"
	"github.com/spf13/cobra"
	"github.com/uptrace/bun"

	"{{.Module}}/internal/infrastructure/config"
	"{{.Module}}/internal/infrastructure/database"
	httpiface "{{.Module}}/internal/interface/http"
	"{{.Module}}/internal/migrations"
)

func main() {
	root := &cobra.Command{
		Use:          "{{.Name}}",
		Short:        "{{.Name}} server",
		Long:         "Run without a subcommand (or with \"serve\") to start the HTTP server. Use \"migrate\" for database migrations.",
		SilenceUsage: true,
	}
	root.RunE = func(cmd *cobra.Command, args []string) error { return runServe(false) }
	root.AddCommand(serveCmd())
	root.AddCommand(fhmigrate.NewCommand(openDB, migrations.Migrations))
	if err := root.Execute(); err != nil {
		log.Fatal(err)
	}
}

func serveCmd() *cobra.Command {
	var autoMigrate bool
	cmd := &cobra.Command{
		Use:   "serve",
		Short: "run the HTTP server",
		RunE:  func(cmd *cobra.Command, args []string) error { return runServe(autoMigrate) },
	}
	cmd.Flags().BoolVar(&autoMigrate, "auto-migrate", false, "create tables at startup (dev)")
	return cmd
}

func runServe(autoMigrate bool) error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	db, err := database.New(cfg.DatabaseURL)
	if err != nil {
		return err
	}

	app := bootstrap.New(bootstrap.Options{
		DB:           db,
		AutoMigrate:  cfg.AutoMigrate || autoMigrate,
		EnableCORS:   true,
		RateLimit:    100,
		HealthChecks: []health.NamedCheck{health.PingBun(db)},
	})

	// app.App is the embedded *fiber.App; app.Mount (below) is bootstrap.App's module-aware method.
	httpiface.Register(app.App)
{{if .Sample}}	if err := app.Mount(httpiface.NewUserModule(db)); err != nil {
		return err
	}
{{end}}
	fmt.Printf("listening on :%s\n", cfg.Port)
	return app.Run(":" + cfg.Port)
}

func openDB(ctx context.Context) (*bun.DB, error) {
	cfg, err := config.Load()
	if err != nil {
		return nil, err
	}
	return database.New(cfg.DatabaseURL)
}
