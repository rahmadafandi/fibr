{{if eq .DB "postgres"}}DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable{{else}}DATABASE_URL=file:./data/app.db?cache=shared{{end}}
PORT=3000
LOG_LEVEL=info
AUTO_MIGRATE=false
# optional: expose Prometheus metrics at /metrics
# METRICS_ENABLED=false
# optional: OpenTelemetry tracing (OTLP/HTTP)
# TRACING_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME={{.Name}}
{{if .Auth}}# generated dev secret — set a unique value per environment, do not reuse in production
JWT_SECRET={{.JWTSecret}}
{{if not .Queue}}# optional: redis-backed token revocation; falls back to an in-memory store if unset
# REDIS_URL=redis://localhost:6379/0
{{end}}{{end}}{{if .Queue}}# background jobs (asynq): REDIS_URL enables the queue + monitoring UI (also used for auth token revocation)
REDIS_URL=redis://localhost:6379/0
QUEUE_CONCURRENCY=10
ASYNQMON_PATH=/monitoring
{{end}}
