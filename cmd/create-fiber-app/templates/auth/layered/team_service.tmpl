package service

import (
	"context"
	"errors"
	"fmt"
	"strings"

	"{{.Module}}/internal/model"
	"{{.Module}}/internal/repository"
)

// Service errors.
var (
	ErrAccountNotFound   = errors.New("account not found")
	ErrAlreadyMember     = errors.New("already a member")
	ErrNotAMember        = errors.New("not a member")
	ErrRoleExists        = errors.New("role already exists")
	ErrRoleNotFound      = errors.New("role not found")
	ErrRoleInUse         = errors.New("role is assigned to members")
	ErrProtectedRole     = errors.New("role is protected")
	ErrInvalidPermission = errors.New("unknown permission")
)

// AllPermissions is the catalog of permissions roles may grant. Edit freely.
var AllPermissions = []string{
	"team:manage",
	"member:manage",
	"role:manage",
	"post:read",
	"post:write",
}

// defaultRoles seeds a new team's roles. Edit freely.
var defaultRoles = map[string][]string{
	"owner":  {"team:manage", "member:manage", "role:manage", "post:read", "post:write"},
	"admin":  {"member:manage", "role:manage", "post:read", "post:write"},
	"member": {"post:read", "post:write"},
	"viewer": {"post:read"},
}

func validPermission(p string) bool {
	for _, a := range AllPermissions {
		if a == p {
			return true
		}
	}
	return false
}

// dedupe returns perms with duplicates removed, preserving order.
func dedupe(perms []string) []string {
	seen := make(map[string]struct{}, len(perms))
	out := make([]string, 0, len(perms))
	for _, p := range perms {
		if _, ok := seen[p]; ok {
			continue
		}
		seen[p] = struct{}{}
		out = append(out, p)
	}
	return out
}

// TeamService holds team use cases.
type TeamService struct {
	repo     *repository.TeamRepository
	accounts *repository.AccountRepository
}

// NewTeamService creates a TeamService.
func NewTeamService(repo *repository.TeamRepository, accounts *repository.AccountRepository) *TeamService {
	return &TeamService{repo: repo, accounts: accounts}
}

func (s *TeamService) seedRoles(ctx context.Context, teamID int64) error {
	for name, perms := range defaultRoles {
		if err := s.repo.CreateRole(ctx, &model.Role{TeamID: teamID, Name: name, Permissions: perms}); err != nil {
			return err
		}
	}
	return nil
}

// CreatePersonalTeam creates a starter team (seeded with default roles) owned by
// the account.
func (s *TeamService) CreatePersonalTeam(ctx context.Context, accountID int64, email string) (*model.Team, error) {
	name := email
	if i := strings.IndexByte(email, '@'); i > 0 {
		name = email[:i]
	}
	t := &model.Team{Name: name + "'s team", Slug: fmt.Sprintf("team-%d", accountID), OwnerAccountID: accountID}
	if err := s.repo.CreateTeam(ctx, t); err != nil {
		return nil, err
	}
	if err := s.seedRoles(ctx, t.ID); err != nil {
		return nil, err
	}
	if err := s.repo.CreateMembership(ctx, &model.Membership{AccountID: accountID, TeamID: t.ID, Role: "owner"}); err != nil {
		return nil, err
	}
	return t, nil
}

// CreateTeam creates a team (seeded with default roles); the caller becomes owner.
func (s *TeamService) CreateTeam(ctx context.Context, accountID int64, name string) (*model.Team, error) {
	t := &model.Team{Name: name, Slug: fmt.Sprintf("team-%d-%s", accountID, slugify(name)), OwnerAccountID: accountID}
	if err := s.repo.CreateTeam(ctx, t); err != nil {
		return nil, err
	}
	if err := s.seedRoles(ctx, t.ID); err != nil {
		return nil, err
	}
	if err := s.repo.CreateMembership(ctx, &model.Membership{AccountID: accountID, TeamID: t.ID, Role: "owner"}); err != nil {
		return nil, err
	}
	return t, nil
}

// Teams returns the teams the account belongs to.
func (s *TeamService) Teams(ctx context.Context, accountID int64) ([]model.Team, error) {
	return s.repo.TeamsForAccount(ctx, accountID)
}

// Membership returns the account's membership in a team (error if not a member).
func (s *TeamService) Membership(ctx context.Context, accountID, teamID int64) (*model.Membership, error) {
	return s.repo.FindMembership(ctx, accountID, teamID)
}

// DefaultMembership returns the account's default (first) membership.
func (s *TeamService) DefaultMembership(ctx context.Context, accountID int64) (*model.Membership, error) {
	return s.repo.FirstMembership(ctx, accountID)
}

// PermissionsForRole returns the permissions granted by a team's named role.
func (s *TeamService) PermissionsForRole(ctx context.Context, teamID int64, roleName string) ([]string, error) {
	return s.repo.PermissionsForRole(ctx, teamID, roleName)
}

// AddMemberByEmail adds the account with the given email to a team with role.
func (s *TeamService) AddMemberByEmail(ctx context.Context, teamID int64, email, role string) (*model.Membership, error) {
	if _, err := s.repo.FindRole(ctx, teamID, role); err != nil {
		return nil, ErrRoleNotFound
	}
	a, err := s.accounts.FindByEmail(ctx, email)
	if err != nil || a == nil {
		return nil, ErrAccountNotFound
	}
	if existing, _ := s.repo.FindMembership(ctx, a.ID, teamID); existing != nil {
		return nil, ErrAlreadyMember
	}
	m := &model.Membership{AccountID: a.ID, TeamID: teamID, Role: role}
	if err := s.repo.CreateMembership(ctx, m); err != nil {
		return nil, err
	}
	return m, nil
}

// ChangeMemberRole reassigns an existing member to a different (existing) role.
func (s *TeamService) ChangeMemberRole(ctx context.Context, teamID int64, email, role string) (*model.Membership, error) {
	if _, err := s.repo.FindRole(ctx, teamID, role); err != nil {
		return nil, ErrRoleNotFound
	}
	a, err := s.accounts.FindByEmail(ctx, email)
	if err != nil || a == nil {
		return nil, ErrAccountNotFound
	}
	m, err := s.repo.FindMembership(ctx, a.ID, teamID)
	if err != nil || m == nil {
		return nil, ErrNotAMember
	}
	if err := s.repo.UpdateMembershipRole(ctx, a.ID, teamID, role); err != nil {
		return nil, err
	}
	m.Role = role
	return m, nil
}

// ListRoles returns the team's roles with their permissions.
func (s *TeamService) ListRoles(ctx context.Context, teamID int64) ([]model.Role, error) {
	return s.repo.RolesForTeam(ctx, teamID)
}

// CreateRole creates a custom role after validating its permissions.
func (s *TeamService) CreateRole(ctx context.Context, teamID int64, name string, perms []string) (*model.Role, error) {
	for _, p := range perms {
		if !validPermission(p) {
			return nil, ErrInvalidPermission
		}
	}
	perms = dedupe(perms)
	if existing, _ := s.repo.FindRole(ctx, teamID, name); existing != nil {
		return nil, ErrRoleExists
	}
	role := &model.Role{TeamID: teamID, Name: name, Permissions: perms}
	if err := s.repo.CreateRole(ctx, role); err != nil {
		return nil, err
	}
	return role, nil
}

// UpdateRolePermissions replaces a role's permission set.
func (s *TeamService) UpdateRolePermissions(ctx context.Context, teamID int64, name string, perms []string) (*model.Role, error) {
	for _, p := range perms {
		if !validPermission(p) {
			return nil, ErrInvalidPermission
		}
	}
	perms = dedupe(perms)
	role, err := s.repo.FindRole(ctx, teamID, name)
	if err != nil {
		return nil, ErrRoleNotFound
	}
	if err := s.repo.SetRolePermissions(ctx, role.ID, perms); err != nil {
		return nil, err
	}
	role.Permissions = perms
	return role, nil
}

// DeleteRole removes a custom role. The "owner" role is protected, and a role
// still assigned to members cannot be deleted.
func (s *TeamService) DeleteRole(ctx context.Context, teamID int64, name string) error {
	if name == "owner" {
		return ErrProtectedRole
	}
	role, err := s.repo.FindRole(ctx, teamID, name)
	if err != nil {
		return ErrRoleNotFound
	}
	n, err := s.repo.CountMembersWithRole(ctx, teamID, name)
	if err != nil {
		return err
	}
	if n > 0 {
		return ErrRoleInUse
	}
	return s.repo.DeleteRole(ctx, role.ID)
}

func slugify(s string) string {
	s = strings.ToLower(strings.TrimSpace(s))
	var b strings.Builder
	for _, r := range s {
		switch {
		case r >= 'a' && r <= 'z', r >= '0' && r <= '9':
			b.WriteRune(r)
		case r == ' ' || r == '-' || r == '_':
			b.WriteByte('-')
		}
	}
	out := b.String()
	if out == "" {
		out = "team"
	}
	return out
}
