		// best-effort: the invitation row + token are already persisted, so a
		// delivery failure must not fail the request.
		_ = s.sender.Send(ctx, fhmailer.Message{To: []string{email}, Subject: "You're invited", HTML: html, Text: text})
	}
{{end}}	return token, inv, nil
