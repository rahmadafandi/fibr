package repository

import (
	"context"

	"{{.Module}}/internal/model"
	"github.com/uptrace/bun"
)

// TeamRepository is the Bun-backed team/membership/role store.
type TeamRepository struct {
	db *bun.DB
}

// NewTeamRepository creates a TeamRepository.
func NewTeamRepository(db *bun.DB) *TeamRepository {
	return &TeamRepository{db: db}
}

// MigrateTeam creates the teams, memberships, roles, role_permissions, and
// invitations tables (and their unique indexes) if they do not exist.
func MigrateTeam(ctx context.Context, db *bun.DB) error {
	if _, err := db.NewCreateTable().Model((*model.Team)(nil)).IfNotExists().Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateTable().Model((*model.Membership)(nil)).IfNotExists().Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateIndex().Model((*model.Membership)(nil)).
		IfNotExists().Index("memberships_account_team_uq").Unique().
		Column("account_id", "team_id").Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateTable().Model((*model.RoleModel)(nil)).IfNotExists().Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateIndex().Model((*model.RoleModel)(nil)).
		IfNotExists().Index("roles_team_name_uq").Unique().
		Column("team_id", "name").Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateTable().Model((*model.RolePermission)(nil)).IfNotExists().Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateIndex().Model((*model.RolePermission)(nil)).
		IfNotExists().Index("role_permissions_role_perm_uq").Unique().
		Column("role_id", "permission").Exec(ctx); err != nil {
		return err
	}
	if _, err := db.NewCreateTable().Model((*model.Invitation)(nil)).IfNotExists().Exec(ctx); err != nil {
		return err
	}
	_, err := db.NewCreateIndex().Model((*model.Invitation)(nil)).
		IfNotExists().Index("invitations_jti_uq").Unique().
		Column("jti").Exec(ctx)
	return err
}

// CreateTeam inserts a new team.
func (r *TeamRepository) CreateTeam(ctx context.Context, t *model.Team) error {
	_, err := r.db.NewInsert().Model(t).Exec(ctx)
	return err
}

// CreateMembership inserts a new membership.
func (r *TeamRepository) CreateMembership(ctx context.Context, m *model.Membership) error {
	_, err := r.db.NewInsert().Model(m).Exec(ctx)
	return err
}

// TeamsForAccount returns the teams the account belongs to.
func (r *TeamRepository) TeamsForAccount(ctx context.Context, accountID int64) ([]model.Team, error) {
	var teams []model.Team
	err := r.db.NewSelect().Model(&teams).
		Join("JOIN memberships AS m ON m.team_id = team.id").
		Where("m.account_id = ?", accountID).
		Order("team.id ASC").
		Scan(ctx)
	return teams, err
}

// FindMembership returns the account's membership in a team, or an error if absent.
func (r *TeamRepository) FindMembership(ctx context.Context, accountID, teamID int64) (*model.Membership, error) {
	m := new(model.Membership)
	err := r.db.NewSelect().Model(m).
		Where("account_id = ?", accountID).Where("team_id = ?", teamID).Scan(ctx)
	if err != nil {
		return nil, err
	}
	return m, nil
}

// FirstMembership returns the account's earliest membership (its default team).
func (r *TeamRepository) FirstMembership(ctx context.Context, accountID int64) (*model.Membership, error) {
	m := new(model.Membership)
	err := r.db.NewSelect().Model(m).
		Where("account_id = ?", accountID).Order("id ASC").Limit(1).Scan(ctx)
	if err != nil {
		return nil, err
	}
	return m, nil
}

// UpdateMembershipRole changes an account's role in a team.
func (r *TeamRepository) UpdateMembershipRole(ctx context.Context, accountID, teamID int64, role string) error {
	_, err := r.db.NewUpdate().Model((*model.Membership)(nil)).
		Set("role = ?", role).
		Where("account_id = ?", accountID).Where("team_id = ?", teamID).Exec(ctx)
	return err
}

// CountMembersWithRole counts memberships in a team holding the named role.
func (r *TeamRepository) CountMembersWithRole(ctx context.Context, teamID int64, name string) (int, error) {
	return r.db.NewSelect().Model((*model.Membership)(nil)).
		Where("team_id = ?", teamID).Where("role = ?", name).Count(ctx)
}

func (r *TeamRepository) permsForRoleID(ctx context.Context, roleID int64) ([]string, error) {
	var perms []string
	err := r.db.NewSelect().Model((*model.RolePermission)(nil)).
		Column("permission").Where("role_id = ?", roleID).Order("permission ASC").Scan(ctx, &perms)
	if err != nil {
		return nil, err
	}
	return perms, nil
}

func insertPerms(ctx context.Context, db bun.IDB, roleID int64, perms []string) error {
	for _, p := range perms {
		if _, err := db.NewInsert().Model(&model.RolePermission{RoleID: roleID, Permission: p}).Exec(ctx); err != nil {
			return err
		}
	}
	return nil
}

// CreateRole inserts a role and its permissions in one transaction.
func (r *TeamRepository) CreateRole(ctx context.Context, role *model.Role) error {
	return r.db.RunInTx(ctx, nil, func(ctx context.Context, tx bun.Tx) error {
		rm := &model.RoleModel{TeamID: role.TeamID, Name: role.Name}
		if _, err := tx.NewInsert().Model(rm).Exec(ctx); err != nil {
			return err
		}
		role.ID = rm.ID
		return insertPerms(ctx, tx, rm.ID, role.Permissions)
	})
}

// RolesForTeam returns the team's roles with their permissions.
func (r *TeamRepository) RolesForTeam(ctx context.Context, teamID int64) ([]model.Role, error) {
	var rows []model.RoleModel
	if err := r.db.NewSelect().Model(&rows).Where("team_id = ?", teamID).Order("id ASC").Scan(ctx); err != nil {
		return nil, err
	}
	out := make([]model.Role, len(rows))
	for i, rm := range rows {
		perms, err := r.permsForRoleID(ctx, rm.ID)
		if err != nil {
			return nil, err
		}
		out[i] = model.Role{ID: rm.ID, TeamID: rm.TeamID, Name: rm.Name, Permissions: perms}
	}
	return out, nil
}

// FindRole returns a team's role by name, or an error if absent.
func (r *TeamRepository) FindRole(ctx context.Context, teamID int64, name string) (*model.Role, error) {
	rm := new(model.RoleModel)
	if err := r.db.NewSelect().Model(rm).Where("team_id = ?", teamID).Where("name = ?", name).Scan(ctx); err != nil {
		return nil, err
	}
	perms, err := r.permsForRoleID(ctx, rm.ID)
	if err != nil {
		return nil, err
	}
	return &model.Role{ID: rm.ID, TeamID: rm.TeamID, Name: rm.Name, Permissions: perms}, nil
}

// SetRolePermissions replaces a role's permissions atomically.
func (r *TeamRepository) SetRolePermissions(ctx context.Context, roleID int64, perms []string) error {
	return r.db.RunInTx(ctx, nil, func(ctx context.Context, tx bun.Tx) error {
		if _, err := tx.NewDelete().Model((*model.RolePermission)(nil)).Where("role_id = ?", roleID).Exec(ctx); err != nil {
			return err
		}
		return insertPerms(ctx, tx, roleID, perms)
	})
}

// DeleteRole removes a role and its permissions atomically.
func (r *TeamRepository) DeleteRole(ctx context.Context, roleID int64) error {
	return r.db.RunInTx(ctx, nil, func(ctx context.Context, tx bun.Tx) error {
		if _, err := tx.NewDelete().Model((*model.RolePermission)(nil)).Where("role_id = ?", roleID).Exec(ctx); err != nil {
			return err
		}
		_, err := tx.NewDelete().Model((*model.RoleModel)(nil)).Where("id = ?", roleID).Exec(ctx)
		return err
	})
}

// PermissionsForRole returns the permission keys granted by a team's named role.
func (r *TeamRepository) PermissionsForRole(ctx context.Context, teamID int64, name string) ([]string, error) {
	var perms []string
	err := r.db.NewSelect().Model((*model.RolePermission)(nil)).
		Column("role_permission.permission").
		Join("JOIN roles AS role ON role.id = role_permission.role_id").
		Where("role.team_id = ?", teamID).Where("role.name = ?", name).
		Order("role_permission.permission ASC").
		Scan(ctx, &perms)
	if err != nil {
		return nil, err
	}
	return perms, nil
}

// CreateInvitation inserts a new invitation.
func (r *TeamRepository) CreateInvitation(ctx context.Context, inv *model.Invitation) error {
	_, err := r.db.NewInsert().Model(inv).Exec(ctx)
	return err
}

// PendingInvitations returns a team's pending invitations.
func (r *TeamRepository) PendingInvitations(ctx context.Context, teamID int64) ([]model.Invitation, error) {
	var rows []model.Invitation
	err := r.db.NewSelect().Model(&rows).
		Where("team_id = ?", teamID).Where("status = ?", "pending").
		Order("id ASC").Scan(ctx)
	return rows, err
}

// FindInvitation returns an invitation by id within a team, or an error if absent.
func (r *TeamRepository) FindInvitation(ctx context.Context, teamID, inviteID int64) (*model.Invitation, error) {
	m := new(model.Invitation)
	err := r.db.NewSelect().Model(m).
		Where("id = ?", inviteID).Where("team_id = ?", teamID).Scan(ctx)
	if err != nil {
		return nil, err
	}
	return m, nil
}

// FindInvitationByJTI returns an invitation by its token jti, or an error if absent.
func (r *TeamRepository) FindInvitationByJTI(ctx context.Context, jti string) (*model.Invitation, error) {
	m := new(model.Invitation)
	if err := r.db.NewSelect().Model(m).Where("jti = ?", jti).Scan(ctx); err != nil {
		return nil, err
	}
	return m, nil
}

// SetInvitationStatus updates an invitation's status.
func (r *TeamRepository) SetInvitationStatus(ctx context.Context, id int64, status string) error {
	_, err := r.db.NewUpdate().Model((*model.Invitation)(nil)).
		Set("status = ?", status).Where("id = ?", id).Exec(ctx)
	return err
}
