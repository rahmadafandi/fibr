package model

import "github.com/uptrace/bun"

// Team is a workspace that accounts belong to via memberships.
type Team struct {
	bun.BaseModel  `bun:"table:teams,alias:team" json:"-"`
	ID             int64  `bun:"id,pk,autoincrement" json:"id"`
	Name           string `bun:"name" json:"name"`
	Slug           string `bun:"slug,unique" json:"slug"`
	OwnerAccountID int64  `bun:"owner_account_id" json:"owner_account_id"`
}

// Membership links an account to a team with a role.
type Membership struct {
	bun.BaseModel `bun:"table:memberships,alias:membership" json:"-"`
	ID            int64  `bun:"id,pk,autoincrement" json:"id"`
	AccountID     int64  `bun:"account_id" json:"account_id"`
	TeamID        int64  `bun:"team_id" json:"team_id"`
	Role          string `bun:"role" json:"role"`
}

// RoleModel is a team-scoped role row.
type RoleModel struct {
	bun.BaseModel `bun:"table:roles,alias:role" json:"-"`
	ID            int64  `bun:"id,pk,autoincrement" json:"id"`
	TeamID        int64  `bun:"team_id" json:"team_id"`
	Name          string `bun:"name" json:"name"`
}

// RolePermission grants a permission to a role.
type RolePermission struct {
	bun.BaseModel `bun:"table:role_permissions,alias:role_permission" json:"-"`
	ID            int64  `bun:"id,pk,autoincrement" json:"id"`
	RoleID        int64  `bun:"role_id" json:"role_id"`
	Permission    string `bun:"permission" json:"permission"`
}

// Role is the API view of a role with its permissions.
type Role struct {
	ID          int64    `json:"id"`
	TeamID      int64    `json:"team_id"`
	Name        string   `json:"name"`
	Permissions []string `json:"permissions"`
}
