package handler

import (
	"context"

	"github.com/gofiber/fiber/v2"
	"github.com/rahmadafandi/fiber-helpers/auth"
	"github.com/rahmadafandi/fiber-helpers/bootstrap"
{{if .Mailer}}	fhmailer "github.com/rahmadafandi/fiber-helpers/mailer"
{{end}}	"github.com/uptrace/bun"

	"{{.Module}}/internal/repository"
	"{{.Module}}/internal/service"
)

// AuthModule wires the auth + team feature.
type AuthModule struct {
	db      *bun.DB
	handler *AuthHandler
}

// NewAuthModule builds the auth module. Pass the result to app.Mount.
func NewAuthModule(db *bun.DB, secret string, store auth.TokenStore{{if .Mailer}}, sender fhmailer.Sender{{end}}) bootstrap.Module {
	accountRepo := repository.NewAccountRepository(db)
	teamRepo := repository.NewTeamRepository(db)
	accountSvc := service.NewAuthService(accountRepo)
	teamSvc := service.NewTeamService(teamRepo, accountRepo, secret{{if .Mailer}}, sender{{end}})
	return &AuthModule{db: db, handler: NewAuthHandler(accountSvc, teamSvc, secret, store)}
}

// Name identifies the module.
func (m *AuthModule) Name() string { return "auth" }

// Register mounts the auth and team routes.
func (m *AuthModule) Register(r fiber.Router) error {
	m.handler.RegisterRoutes(r)
	return nil
}

// Migrate creates the accounts, teams, and memberships tables if absent.
func (m *AuthModule) Migrate(ctx context.Context) error {
	if err := repository.MigrateAccount(ctx, m.db); err != nil {
		return err
	}
	return repository.MigrateTeam(ctx, m.db)
}
