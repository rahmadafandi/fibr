package team

import "context"

// Repository is the team/membership/role persistence port.
type Repository interface {
	CreateTeam(ctx context.Context, t *Team) error
	CreateMembership(ctx context.Context, m *Membership) error
	TeamsForAccount(ctx context.Context, accountID int64) ([]Team, error)
	FindMembership(ctx context.Context, accountID, teamID int64) (*Membership, error)
	FirstMembership(ctx context.Context, accountID int64) (*Membership, error)
	UpdateMembershipRole(ctx context.Context, accountID, teamID int64, role string) error
	CountMembersWithRole(ctx context.Context, teamID int64, name string) (int, error)

	CreateRole(ctx context.Context, role *Role) error
	RolesForTeam(ctx context.Context, teamID int64) ([]Role, error)
	FindRole(ctx context.Context, teamID int64, name string) (*Role, error)
	SetRolePermissions(ctx context.Context, roleID int64, perms []string) error
	DeleteRole(ctx context.Context, roleID int64) error
	PermissionsForRole(ctx context.Context, teamID int64, name string) ([]string, error)

	FindTeam(ctx context.Context, teamID int64) (*Team, error)
	UpdateTeamName(ctx context.Context, teamID int64, name string) error
	DeleteMembership(ctx context.Context, accountID, teamID int64) error
	DeleteTeamCascade(ctx context.Context, teamID int64) error
	TransferOwnership(ctx context.Context, teamID, newOwnerID, oldOwnerID int64) error

	CreateInvitation(ctx context.Context, inv *Invitation) error
	PendingInvitations(ctx context.Context, teamID int64) ([]Invitation, error)
	FindInvitation(ctx context.Context, teamID, inviteID int64) (*Invitation, error)
	FindInvitationByJTI(ctx context.Context, jti string) (*Invitation, error)
	SetInvitationStatus(ctx context.Context, id int64, status string) error
}
