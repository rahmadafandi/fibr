package router

import (
	"github.com/gofiber/fiber/v2"
	"github.com/rahmadafandi/fiber-helpers/response"
{{if .Sample}}	"{{.Module}}/internal/handler"
{{end}})

{{if .Sample}}// Register wires the root route and the user handler routes.
func Register(app fiber.Router, userHandler *handler.UserHandler) {
	app.Get("/", root)
	userHandler.RegisterRoutes(app)
}
{{else}}// Register wires the root route.
func Register(app fiber.Router) {
	app.Get("/", root)
}
{{end}}
func root(c *fiber.Ctx) error {
	return response.SendSuccess(c, fiber.Map{"name": "{{.Name}}"}, "ok")
}
