func main() {
	root := &cobra.Command{
		Use:          "{{.Name}}",
		Short:        "{{.Name}} server",
		Long:         "Run without a subcommand (or with \"serve\") to start the HTTP server. Use \"migrate\" for database migrations.",
		SilenceUsage: true,
	}
	root.RunE = func(cmd *cobra.Command, args []string) error { return runServe(false) }
	root.AddCommand(serveCmd())
	root.AddCommand(fhmigrate.NewCommand(openDB, migrations.Migrations))
{{if .Queue}}	root.AddCommand(workerCmd())
{{end}}	if err := root.Execute(); err != nil {
		log.Fatal(err)
	}
}

func serveCmd() *cobra.Command {
	var autoMigrate bool
	cmd := &cobra.Command{
		Use:   "serve",
		Short: "run the HTTP server",
		RunE:  func(cmd *cobra.Command, args []string) error { return runServe(autoMigrate) },
	}
	cmd.Flags().BoolVar(&autoMigrate, "auto-migrate", false, "create tables at startup (dev)")
	return cmd
}

{{if .Queue}}func workerCmd() *cobra.Command {
	return &cobra.Command{
		Use:   "worker",
		Short: "run the background job worker",
		RunE:  func(cmd *cobra.Command, args []string) error { return runWorker() },
	}
}

func runWorker() error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	if cfg.RedisURL == "" {
		return fmt.Errorf("worker requires REDIS_URL")
	}
	opt, err := fhjobs.RedisConnOpt(cfg.RedisURL)
	if err != nil {
		return err
	}
	srv := fhjobs.NewServer(opt, fhjobs.ServerConfig{Concurrency: cfg.QueueConcurrency})
	appjobs.Register(srv)
	log.Println("worker started")
	return srv.Run()
}

{{end}}func runServe(autoMigrate bool) error {
	cfg, err := config.Load()
	if err != nil {
		return err
	}
	db, err := fhdatabase.NewBun(cfg.DatabaseURL)
	if err != nil {
		return err
	}

	var cleanups []func(context.Context) error
	if cfg.TracingEnabled {
		shutdown, terr := tracing.Setup(context.Background(), tracing.WithServiceName("{{.Name}}"))
		if terr != nil {
			log.Printf("tracing setup failed; continuing without tracing: %v", terr)
		} else {
			cleanups = append(cleanups, shutdown)
		}
	}

{{if .Queue}}	var queueClient *fhjobs.Client
	var asynqmonMount *bootstrap.AsynqmonMount
	if cfg.RedisURL != "" {
		opt, qerr := fhjobs.RedisConnOpt(cfg.RedisURL)
		if qerr != nil {
			return qerr
		}
		queueClient = fhjobs.NewClient(opt)
		cleanups = append(cleanups, func(ctx context.Context) error { return queueClient.Close() })
		asynqmonMount = &bootstrap.AsynqmonMount{
			Handler: fhjobs.MonitoringHandler(opt, cfg.AsynqmonPath),
			Path:    cfg.AsynqmonPath,
{{if .Auth}}			Middleware: []fiber.Handler{fhauth.RequireAuth(cfg.JWTSecret)},
{{end}}		}
	} else {
		log.Println("queue disabled — set REDIS_URL to enable background jobs")
	}

{{end}}	app := bootstrap.New(bootstrap.Options{
		DB:           db,
		AutoMigrate:  cfg.AutoMigrate || autoMigrate,
		Metrics:      cfg.MetricsEnabled,
		Tracing:      cfg.TracingEnabled,
		Cleanup:      cleanups,
{{if .Queue}}		Asynqmon:     asynqmonMount,
{{end}}		EnableCORS:   true,
		RateLimit:    100,
		HealthChecks: []health.NamedCheck{health.PingBun(db)},
	})

	// app.App is the embedded *fiber.App; app.Mount (below) is bootstrap.App's module-aware method.
	router.Register(app.App)
{{if .Queue}}	if queueClient != nil {
		app.Post("/jobs/welcome", func(c *fiber.Ctx) error {
			info, err := queueClient.Enqueue(c.UserContext(), appjobs.WelcomeType, appjobs.WelcomePayload{Email: "user@example.com"})
			if err != nil {
				return err
			}
			return c.JSON(fiber.Map{"enqueued": info.ID})
		})
	}
{{end}}{{if .Sample}}	if err := app.Mount(handler.NewUserModule(db)); err != nil {
		return err
	}
{{end}}{{if .Auth}}	var authStore fhauth.TokenStore
	if cfg.RedisURL != "" {
		opt, err := fhredis.ParseRedisOptions(cfg.RedisURL)
		if err != nil {
			return err
		}
		authStore = fhauth.NewRedisStore(fhredis.New(redislib.NewClient(opt)))
	} else {
		zlog.Warn().Msg("auth revocation using in-memory store — set REDIS_URL for production")
		authStore = fhauth.NewMemoryStore()
	}
	if err := app.Mount(handler.NewAuthModule(db, cfg.JWTSecret, authStore)); err != nil {
		return err
	}
{{end}}
	fmt.Printf("listening on :%s\n", cfg.Port)
	return app.Run(":" + cfg.Port)
}

func openDB(ctx context.Context) (*bun.DB, error) {
	cfg, err := config.Load()
	if err != nil {
		return nil, err
	}
	return fhdatabase.NewBun(cfg.DatabaseURL)
}
