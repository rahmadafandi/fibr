package config

import fhconfig "github.com/rahmadafandi/fiber-helpers/config"

// Config holds all environment-driven configuration for {{.Name}}.
type Config struct {
	DatabaseURL string `mapstructure:"DATABASE_URL" default:"{{if eq .DB "postgres"}}postgres://app:app@localhost:5432/app?sslmode=disable{{else}}file:./data/app.db?cache=shared{{end}}"`
	Port        string `mapstructure:"PORT" default:"3000"`
	LogLevel    string `mapstructure:"LOG_LEVEL" default:"info"`
	AutoMigrate bool   `mapstructure:"AUTO_MIGRATE" default:"false"`
{{if .Auth}}	JWTSecret string `mapstructure:"JWT_SECRET" required:"true"`
{{end}}}

// Load reads configuration from environment variables and defaults.
func Load() (*Config, error) {
	var c Config
	if err := fhconfig.LoadConfig(&c); err != nil {
		return nil, err
	}
	return &c, nil
}
