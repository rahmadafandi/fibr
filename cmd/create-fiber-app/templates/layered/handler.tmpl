package handler

import (
	"strconv"

	"github.com/gofiber/fiber/v2"
	"github.com/rahmadafandi/fiber-helpers/response"
	"{{.Module}}/internal/model"
	"{{.Module}}/internal/service"
)

// UserHandler exposes user HTTP routes.
type UserHandler struct {
	svc *service.UserService
}

func NewUserHandler(svc *service.UserService) *UserHandler {
	return &UserHandler{svc: svc}
}

func (h *UserHandler) RegisterRoutes(app fiber.Router) {
	g := app.Group("/users")
	g.Get("/", h.list)
	g.Get("/:id", h.get)
	g.Post("/", h.create)
}

func (h *UserHandler) list(c *fiber.Ctx) error {
	users, err := h.svc.List(c.UserContext())
	if err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
	}
	return response.SendSuccess(c, users, "ok")
}

func (h *UserHandler) get(c *fiber.Ctx) error {
	id, err := strconv.ParseInt(c.Params("id"), 10, 64)
	if err != nil {
		return response.SendError(c, nil, "invalid id", fiber.StatusBadRequest)
	}
	u, err := h.svc.Get(c.UserContext(), id)
	if err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusNotFound)
	}
	return response.SendSuccess(c, u, "ok")
}

func (h *UserHandler) create(c *fiber.Ctx) error {
	var u model.User
	if err := c.BodyParser(&u); err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusBadRequest)
	}
	if err := h.svc.Create(c.UserContext(), &u); err != nil {
		return response.SendError(c, nil, err.Error(), fiber.StatusInternalServerError)
	}
	return response.SendSuccess(c, u, "created", fiber.StatusCreated)
}
